# Local-only settings. Never commit real keys in .env.
RPG_DM_HOST=127.0.0.1
RPG_DM_PORT=8008
RPG_DM_DEFAULT_MODEL=googleapi/gemma-4-31b-it

# Optional local LM Studio backend.
RPG_DM_LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
RPG_DM_LM_STUDIO_API_KEY=

# Optional server-side Google keys for local use.
# Public demo users can enter keys in the web UI instead.
RPG_DM_GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
RPG_DM_GEMINI_API_KEY=
RPG_DM_GEMINI_TTS_API_KEY=
RPG_DM_GEMINI_TTS_API_KEYS=
RPG_DM_GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
RPG_DM_GEMINI_TTS_VOICE=Leda
RPG_DM_GEMINI_API_PROXY_URL=

RPG_DM_NARRATIVE_MAX_TOKENS=4096
RPG_DM_MEMORY_MAX_TOKENS=2048
RPG_DM_RECENT_TURN_WINDOW=10
